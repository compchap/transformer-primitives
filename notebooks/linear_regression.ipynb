   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "9e95b19c-3c4c-4d35-a76b-9289396d3ec8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Normal Equation\n",
    "\n",
    "X = 2 * np.random.rand(100,1)\n",
    "# y = 4 +3X + Gaussian Noise\n",
    "y = 4 + 3 * X + np.random.rand(100, 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "e4b3e484-6d75-4b28-8ae2-7e3662dd6c4b",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_b = np.c_[np.ones((100,1)), X]\n",
    "theta_best = np.linalg.inv(X_b.T.dot(X_b)).dot(X_b.T).dot(y)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "2cba1651-3c34-489e-b987-78e5460790c5",
   "metadata": {},
